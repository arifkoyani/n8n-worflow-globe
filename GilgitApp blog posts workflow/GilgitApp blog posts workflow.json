    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"AI Image Prompt Schema\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"blog_title\": {\n      \"type\": \"string\",\n      \"description\": \"Title of the blog post\"\n    },\n    \"image_prompt\": {\n      \"type\": \"string\",\n      \"description\": \"Initial AI prompt description of the image\"\n    },\n    \"ai_image_config\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"logo\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"file\": { \"type\": \"string\" },\n            \"position\": { \"type\": \"string\" },\n            \"size_percentage\": { \"type\": \"number\" },\n            \"transparent\": { \"type\": \"boolean\" }\n          },\n          \"required\": [\"file\", \"position\", \"size_percentage\", \"transparent\"]\n        },\n        \"background\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"scene\": { \"type\": \"string\" },\n            \"mood\": { \"type\": \"string\" },\n            \"lighting\": { \"type\": \"string\" },\n            \"composition\": { \"type\": \"string\" },\n            \"copy_space\": { \"type\": \"string\" }\n          },\n          \"required\": [\"scene\", \"mood\", \"lighting\", \"composition\", \"copy_space\"]\n        },\n        \"text_overlay\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"headline\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"text\": { \"type\": \"string\" },\n                \"font\": { \"type\": \"string\" },\n                \"style\": { \"type\": \"string\" },\n                \"color\": { \"type\": \"string\" },\n                \"background_box\": { \"type\": \"string\" },\n                \"size_ratio\": { \"type\": \"number\" }\n              },\n              \"required\": [\"text\", \"font\", \"style\", \"color\", \"background_box\", \"size_ratio\"]\n            },\n            \"subheadline\": {\n              \"type\": \"object\",\n              \"properties\": {\n                \"text\": { \"type\": \"string\" },\n                \"font\": { \"type\": \"string\" },\n                \"style\": { \"type\": \"string\" },\n                \"color\": { \"type\": \"string\" },\n                \"size_ratio\": { \"type\": \"number\" },\n                \"separator\": { \"type\": \"string\" }\n              },\n              \"required\": [\"text\", \"font\", \"style\", \"color\", \"size_ratio\", \"separator\"]\n            }\n          },\n          \"required\": [\"headline\", \"subheadline\"]\n        },\n        \"output\": {\n          \"type\": \"object\",\n          \"properties\": {\n            \"format\": { \"type\": \"string\" },\n            \"resolution\": { \"type\": \"string\" }\n          },\n          \"required\": [\"format\", \"resolution\"]\n        }\n      },\n      \"required\": [\"logo\", \"background\", \"text_overlay\", \"output\"]\n    }\n  },\n  \"required\": [\"blog_title\", \"image_prompt\", \"ai_image_config\"]\n}"
      },
