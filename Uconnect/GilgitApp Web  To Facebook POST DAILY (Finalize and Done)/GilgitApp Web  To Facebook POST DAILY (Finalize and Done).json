    {
      "parameters": {
        "promptType": "define",
        "text": "=Generate a Facebook post for the following item data:\n\nItem Data: {{ $('Edit Fields1').first().json.data }}\nItem URL: {{ $json.finalUrl }}\n\nUse all fields such as title, model, price, contact numbers, and link. \nMake it a single continuous text with no line breaks or \\n characters.\nInclude hashtags: according to item details .\nlike example : ==> #gilgitapp #buyandsell #hondacg125 #125bike #usedbikes #ghizer #gilgit #hunza #skardu #gahkuch #chilas\n ",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "=You are a social media post generator. \nCreate a Facebook post description using the item JSON. \nUse all available details: title, model, price, contact, URL. \nAlways generate the output as a single continuous text. Do not include line breaks, new lines, or \\n characters. All information should be in plain text format.\n\nFormat like this:\n\n𝐇𝐨𝐧𝐝𝐚 𝐂𝐆 𝟏𝟐𝟓 𝐁𝐢𝐤𝐞 𝐟𝐨𝐫 𝐒𝐚𝐥𝐞 𝐢𝐧 𝐆𝐢𝐥𝐠𝐢𝐭 ((Urgent Sale!))\n𝐌𝐨𝐝𝐞𝐥: 𝟐𝟎𝟏𝟗\n𝐏𝐫𝐢𝐜𝐞: 𝐏𝐊𝐑 𝟏𝟓𝟎,𝟎𝟎𝟎\n𝐂𝐨𝐧𝐭𝐚𝐜𝐭 𝐍𝐨: 03165763810 / 92 344 3129046\n𝐌𝐨𝐫𝐞 𝐈𝐧𝐟𝐨: [item URL]\n\nAdd relevant hashtags at the end like This :\n#gilgitapp #buyandsell #hondacg125 #125bike #usedbikes #ghizer #gilgit #hunza #skardu #gahkuch #chilas"
        }
      },
