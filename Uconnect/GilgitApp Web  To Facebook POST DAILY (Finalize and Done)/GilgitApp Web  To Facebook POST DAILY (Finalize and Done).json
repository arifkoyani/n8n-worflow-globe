    {
      "parameters": {
        "jsCode": "// Get title and id from input\nconst title = $input.first().json.Title;\nconst id = $input.first().json.id;\n\n// Convert title to URL-friendly slug\nconst slug = title\n  .toLowerCase()                  // convert to lowercase\n  .replace(/[^a-z0-9\\s-]/g, '')   // remove special characters except letters, numbers, spaces, hyphens\n  .trim()                          // remove extra spaces\n  .replace(/\\s+/g, '-')            // replace spaces with hyphens\n\n// Capitalize first letter of each word (optional, to match your example)\nconst slugCapitalized = slug\n  .split('-')\n  .map(word => word.charAt(0).toUpperCase() + word.slice(1))\n  .join('-');\n\n// Merge into final URL\nconst finalUrl = `https://gilgit.app/details/${slugCapitalized}/${id}`;\n\nreturn { finalUrl };"
      },
